ENVIRONMENT=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

BASE_API_URL=https://api.yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

RESUME_TAILORING_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/tailor-resume
RESUME_INTELLIGENCE_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/resume-intelligence
N8N_VERIFY_SSL=true

JOB_SEARCH_SERVICE_URL=http://job-search-service:8002
AUTO_START_JOB_SEARCH_SERVICE=false
JOB_SEARCH_SERVICE_START_TIMEOUT=20

ENABLE_DEV_ADMIN_ROUTES=false

JOB_MATCH_PRIMARY_MODEL=BAAI/bge-base-en-v1.5
JOB_MATCH_FALLBACK_MODEL=sentence-transformers/all-MiniLM-L6-v2
JOB_MATCH_SKILL_THRESHOLD=0.62
JOB_MATCH_EMBEDDING_CACHE_SIZE=512
EMAIL_PROVIDER=file
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@yourdomain.com


SMTP_TLS=true
BASE_FRONTEND_URL=https://yourdomain.com
EMAIL_TOKEN_EXPIRY=60
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=15
HIGH_MATCH_ALERT_THRESHOLD=90
EMAIL_OUTBOX_DIR=./email_outbox
ENABLE_JOB_SEARCH_SCHEDULER=true
JOB_SEARCH_SCHEDULER_INTERVAL_SECONDS=60
